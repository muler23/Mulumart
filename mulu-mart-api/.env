# Server Configuration
NODE_ENV=development
PORT=5005
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mulumart

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email Configuration (for future use)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASSWORD=your_mailtrap_password
EMAIL_FROM=no-reply@mulumart.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Telebirr Payment Configuration (REAL - Replace with actual credentials)
# Get from Telebirr Ethiopia: support@telebirr.com
TELEBIRR_API_KEY=live_xxxxxxxxxxxxxxxxxxxx
TELEBIRR_SECRET_KEY=sec_xxxxxxxxxxxxxxxxxxxx
TELEBIRR_MERCHANT_ID=your_merchant_id
TELEBIRR_BASE_URL=https://api.telebirr.com
TELEBIRR_WEBHOOK_URL=https://your-domain.com/api/v1/payments/webhook/telebirr

# Bank Payment Configuration (REAL - Replace with actual credentials)
# Contact each bank for API access
CBE_API_KEY=your_cbe_api_key
CBE_SECRET_KEY=your_cbe_secret_key
ABYSSINIA_API_KEY=your_abyssinia_api_key
ABYSSINIA_SECRET_KEY=your_abyssinia_secret_key
AWASH_API_KEY=your_awash_api_key
AWASH_SECRET_KEY=your_awash_secret_key
ZEMEN_API_KEY=your_zemen_api_key
ZEMEN_SECRET_KEY=your_zemen_secret_key
DASHEN_API_KEY=your_dashen_api_key
DASHEN_SECRET_KEY=your_dashen_secret_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15*60*1000 # 15 minutes
RATE_LIMIT_MAX=100

# Ad Configuration
AD_EXPIRY_DAYS=30

# Promotion Tiers (in days)
PROMOTION_BRONZE_DAYS=7
PROMOTION_SILVER_DAYS=14
PROMOTION_GOLD_DAYS=30
